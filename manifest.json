{
  "manifest_version": 3,
  "name": "ClipNext – Smart Clipboard Manager",
  "version": "1.1.0",
  "description": "Capture everything you copy. Access clipboard history for text, screenshots and images instantly, stored locally for total privacy.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "ClipNext",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/injected.js",
        "assets/icons/icon48.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
